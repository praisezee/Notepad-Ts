{
  "name": "notepad",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "start": "postcss src/input.css -o dist/styles.css & tsc & qode ./dist/index.js",
    "build": "tsc",
    "build:css": "postcss src/input.css -o dist/styles.css",
