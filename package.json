    "pack": "nodegui-packer --pack ./dist"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@nodegui/nodegui": "^0.71.0",
    "@types/node": "^22.15.2",
    "ts-node": "^10.9.2"
  }
}
